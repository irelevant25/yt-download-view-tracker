{
  "trailingComma": "all",
  "tabWidth": 4,
  "printWidth": 200,
  "singleQuote": false,
  "overrides": [
    {
      "files": ["*.ts", "*.js"],
      "options": {
        "tabWidth": 2,
        "singleQuote": true
      }
    },
    {
      "files": ["*.json", "*.prettierrc", "*.config.*", "*.scss"],
      "options": {
        "tabWidth": 2,
        "singleQuote": false
      }
    },
    {
      "files": "*.html",
      "options": {
        "trailingComma": "all",
        "tabWidth": 4,
        "semi": true,
        "printWidth": 200,
        "singleQuote": false,
        "bracketSameLine": true,
        "htmlWhitespaceSensitivity": "ignore",
        "bracketSpacing": true,
        "arrowParens": "always",
        "singleAttributePerLine": false
      }
    }
  ]
}
